{
  "name": "my-ax",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "A personal AI agent operating environment you self-host on Cloudflare.",
  "scripts": {
    "dev": "npm run build:assets && wrangler dev --env dev",
    "dev:access": "bash scripts/dev-access.sh worker",
    "dev:access:tunnel": "bash scripts/dev-access.sh tunnel",
    "deploy": "npm run build:assets && wrangler deploy",
    "deploy:dev": "npm run build:assets && wrangler deploy --env dev",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "check": "npm run build:assets && npm run typecheck && npm run test:unit",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply my-ax-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply my-ax-db --local --env dev",
    "build:css": "tailwindcss -i src/styles/app.css -o public/static/styles.css --minify",
    "build:brand": "node scripts/build-brand.mjs",
    "build:assets": "npm run build:css && npm run build:brand && npm run build:vendor && npm run build:svelte",
    "build:svelte": "node proof/svelte/build.mjs",
    "test:tool-widgets": "node proof/svelte/tool-result-widgets-smoke.mjs",
    "test:tool-output-limit": "tsx --test src/tool-output-limit.test.ts",
    "test:run-receipts": "node scripts/test-run-receipts.mjs",
    "prove": "bun proof/plan.ts",
    "prove:artifacts": "node scripts/prove-artifacts.mjs",
    "prove:browser": "node proof/browser-e2e.mjs",
    "prove:models": "node scripts/prove-all-models-http.mjs",
    "prove:all": "npm run check && npm run prove && npm run prove:browser",
    "test:session-entries": "node scripts/test-session-entries.mjs",
    "test:public-url": "node scripts/test-public-url.mjs",
    "test:uploads": "tsx --test src/uploads.test.ts",
    "test:mcp-code-mode": "tsx --test src/mcp-code-mode-policy.test.ts src/code-mode-runtime.test.ts",
    "test:bridge-replay": "tsx --test src/bridge-replay.test.ts",
    "test:workspace-snapshot-ordering": "tsx --test src/workspace-snapshot-ordering.test.ts",
    "test:dead-session": "tsx --test src/dead-session.test.ts",
    "test:deep-links": "tsx --test proof/svelte/deep-links.test.ts",
    "test:attention-state": "tsx --test proof/svelte/attention-state.test.ts",
    "test:session-generation": "tsx --test proof/svelte/session-generation.test.ts",
    "test:unit": "npm run test:models && npm run test:check-in && npm run test:recovery-exhaustion && npm run test:recurring-job-receipt && npm run test:recurring-job-run && npm run test:tool-output-limit && npm run test:dead-session && npm run test:tool-widgets && npm run test:run-receipts && npm run test:session-entries && npm run test:public-url && npm run test:uploads && npm run test:mcp-code-mode && npm run test:bridge-replay && npm run test:workspace-snapshot-ordering && npm run test:deep-links && npm run test:attention-state && npm run test:session-generation && npm run test:decision-response && npm run test:capability-review && npm run test:voice-session-ownership && npm run test:session-ownership && npm run test:job-state",
    "prove:resume": "node scripts/prove-resume.mjs",
    "verify:public": "node scripts/verify-public-clean.mjs",
    "build:vendor": "node scripts/build-vendor.mjs",
    "test:job-state": "tsx --test src/job-state-transition.test.ts src/job-service.test.ts",
    "test:voice-session-ownership": "tsx --test src/voice-session-ownership.test.ts",
    "test:session-ownership": "tsx --test src/session-ownership.test.ts",
    "test:decision-response": "tsx --test src/decision-response.test.ts",
    "test:capability-review": "tsx --test src/capability-review.test.ts",
    "test:recovery-exhaustion": "tsx --test src/recovery-exhaustion.test.ts",
    "test:recurring-job-receipt": "tsx --test src/recurring-job-receipt.test.ts",
    "loop:disagree": "node scripts/loop-disagree.mjs",
    "verify:changed": "npm run build:assets && npm run typecheck && npm run test:unit && npm run verify:public",
    "verify:release": "npm run build:assets && npm run typecheck && npm run test:unit && npm run verify:public",
    "test:recurring-job-run": "tsx --test src/recurring-job-run.test.ts",
    "test:check-in": "tsx --test src/check-in.test.ts",
    "test:models": "tsx --test src/models.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.84",
    "@ai-sdk/openai": "3.0.71",
    "@cloudflare/codemode": "0.4.2",
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/sandbox": "0.12.1",
    "@cloudflare/shell": "0.4.0",
    "@cloudflare/think": "0.11.0",
    "@cloudflare/voice": "0.3.3",
    "agents": "0.17.0",
    "ai": "6.0.205",
    "effect": "3.21.3",
    "hono": "4.12.27",
    "jose": "6.2.3",
    "marked": "14.1.3",
    "rrweb-player": "1.0.0-alpha.4",
    "svelte": "5.56.3",
    "svelte-hono": "0.1.2",
    "workers-ai-provider": "3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@types/node": "25.9.3",
    "esbuild": "0.28.1",
    "esbuild-svelte": "^0.9.5",
    "sharp": "0.35.1",
    "tailwindcss": "4.3.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "wrangler": "4.102.0"
  },
  "author": "Jordan Coeyman (https://coey.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acoyfellow/my-ax.git"
  },
  "homepage": "https://ax.coey.dev",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.13.0"
}
